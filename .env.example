# EtthusHUB Configuration
# Copy this file to .env and customize for your setup

# Hub identity
HUB_NAME=EtthusHUB

# Main API port
PORT=3001

# Hub setup web UI port (open in browser to pair hub with a house)
SETUP_PORT=3002

# Matter persistent storage path
MATTER_STORAGE_PATH=./.matter-storage

# House ID — set automatically after pairing via setup UI.
# You can override it here for headless/automated deployment:
# HUB_HOUSE_ID=xxxxxxxxxxxx

# Firebase configuration (use your own project or the default shared project)
FIREBASE_API_KEY=AIzaSyBD46GyXwLJUHFr-q0GRFbUsWKJsw4omSY
FIREBASE_AUTH_DOMAIN=etthuscontrol-matter.firebaseapp.com
FIREBASE_PROJECT_ID=etthuscontrol-matter
FIREBASE_STORAGE_BUCKET=etthuscontrol-matter.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=267601572566
FIREBASE_APP_ID=1:267601572566:web:fe2dd2cad25a00c9f78f77
FIREBASE_MEASUREMENT_ID=G-M2MCJ3HBXY
FIREBASE_DB_NAME=etthuscontrolmatter

# Log level: debug, info, warn, error
LOG_LEVEL=info
